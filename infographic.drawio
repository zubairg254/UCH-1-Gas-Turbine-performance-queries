        <!-- Corrected Output Box -->
        <mxCell id="corrected-output-box" value="&lt;b&gt;🎯 CORRECTED OUTPUT CALCULATION&lt;/b&gt;&lt;br&gt;&lt;br&gt;CorrectedOutput_MW = MeasuredOutput_MW / Combined_OutputCF&lt;br&gt;&lt;br&gt;CorrectedOutput_MW = 150.5 MW / 1.0156&lt;br&gt;&lt;br&gt;&lt;b&gt;CorrectedOutput_MW = 148.2 MW&lt;/b&gt;&lt;br&gt;&lt;br&gt;(Output normalized to baseline conditions)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E5F5;strokeColor=#7B1FA2;strokeWidth=2;fontColor=#4A148C;fontSize=11;align=center;verticalAlign=middle;arcSize=5;" vertex="1" parent="1">
